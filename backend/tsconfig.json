{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "skipLibCheck": true,
    "moduleResolution": "Node16",
    "resolveJsonModule": true
  },
  "include": ["**/*.js"],
  "exclude": ["node_modules"],
  "typeAcquisition": {
    "enable": false
  }
}
