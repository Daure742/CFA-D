# .env.example - Variables d'environnement (NE PAS COMMITTER VOS SECRETS)
# Copiez ce fichier en `.env` (backend) et `cfa_digital/.env` (frontend) et remplissez

##### Backend (Node.js / Express) #####
# Si vous souhaitez forcer l'utilisation de MongoDB Atlas, définissez `MONGO_URI`.
MONGO_URI=
PORT=5000

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# SMTP (mailer)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Cloudinary (fichiers)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe (paiements, optionnel)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Autres
NODE_ENV=development

##### Frontend (Vite) - variables à placer aussi dans `cfa_digital/.env` #####
# URL de l'API (backend)
VITE_API_URL=http://localhost:5000
# URL du socket si utilisé
VITE_SOCKET_URL=ws://localhost:5000

# Notes:
# - Si `MONGO_URI` est défini (ex: MongoDB Atlas), le backend l'utilisera.
# - Si `MONGO_URI` est vide, le `docker-compose.yml` utilisera l'instance Mongo locale (service `mongo`).