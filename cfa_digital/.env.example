# cfa_digital/.env.example - Variables pour le frontend Vite
# Copier en `cfa_digital/.env` pour le développement local.

# L'URL de l'API backend (doit inclure /api)
VITE_API_URL=https://cfa-backend-vtex.onrender.com/api

# URL du socket backend
VITE_SOCKET_URL=https://cfa-backend-vtex.onrender.com

# Optionnel: outils tiers
VITE_SENTRY_DSN=

# Notes:
# - Préfixer par VITE_ pour que Vite expose ces variables côté client.